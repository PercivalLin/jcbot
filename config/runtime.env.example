# Lobster runtime environment example
# Copy to config/runtime.env before first real run.

LOBSTER_BOOTSTRAPPED=1
LOBSTER_ENV_VERSION=1

# IPC and runtime state
LOBSTER_SOCKET_PATH=/tmp/lobster/lobsterd.sock
LOBSTER_DATA_PATH=/tmp/lobster/lobster.sqlite

# Native bridge
# Set this after building lobster-bridge, for example:
# LOBSTER_BRIDGE_BIN=/absolute/path/to/native/lobster-bridge/.build/release/lobster-bridge

# Telegram ingress
# Prefer file-based secrets so plaintext tokens do not live in the repo.
LOBSTER_TELEGRAM_BOT_TOKEN_FILE=secrets/telegram_bot_token.txt
LOBSTER_TELEGRAM_ALLOWED_CHAT_IDS=
LOBSTER_TELEGRAM_BASE_URL=https://api.telegram.org
# LOBSTER_TELEGRAM_PROXY_URL=http://127.0.0.1:7897
LOBSTER_TELEGRAM_TEXT_MODE=hybrid
LOBSTER_TELEGRAM_TASK_ACK=1
LOBSTER_TELEGRAM_TRACE=1

# Model provider credentials
OPENAI_COMPATIBLE_API_KEY_FILE=secrets/openai_compatible_api_key.txt

# Optional TLS override for corporate/custom proxies
# NODE_EXTRA_CA_CERTS=certs/custom-ca.pem

# Terminal traces
LOBSTER_CHAT_TRACE=1
LOBSTER_MODEL_TRACE=1
